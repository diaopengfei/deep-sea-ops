# deepsea-server 控制面配置文件
# 复制为 server.yaml 后修改。启动时通过 -config config/server.yaml 指定路径,
# 不指定则默认查找 ./config/server.yaml, 文件不存在则用内置默认值。
#
# 配置优先级: 环境变量 > YAML 配置 > 内置默认值
# 多节点 Raft 集群中, security 段的 jwt_secret 和 master_key 必须在所有节点保持一致。

# Raft 节点 ID (集群内唯一, 如 node1 / node2 / node3)
node_id: node1

# Raft 相关配置
raft:
  # 本节点 Raft 通信地址 (多节点部署用内网 IP, 不能用 0.0.0.0)
  addr: 127.0.0.1:7000
  # Raft 数据目录 (日志/快照/bbolt, 必须持久化)
  data_dir: raft-data
  # 加入已有集群时填 Leader 的 Raft 地址; 为空表示自己是首节点(bootstrap)
  join: ""

# HTTP 监听地址 (供前端访问 + REST API)
http:
  addr: :8080

# gRPC 监听地址 (供 Agent 连接)
grpc:
  addr: :9090

# 安全相关配置 (v0.5.1+)
# 多节点 Raft 集群中, jwt_secret 和 master_key 必须在所有节点保持一致。
# 也可通过环境变量覆盖: JWT_SECRET / ADMIN_PASSWORD / MASTER_KEY
security:
  # JWT 签名密钥 (生产必须修改为长随机串)
  # 多节点必须一致: 入口代理转发请求到任意节点, Token 必须被所有节点验证通过
  jwt_secret: "deepsea-dev-secret-change-me"

  # 初始管理员密码 (仅首节点首次启动创建 admin 时生效, 不要求多节点一致)
  # admin 创建后密码 hash 存 Raft 复制到所有节点, 后续启动不再使用此值
  admin_password: "admin123"

  # SSH 凭据 AES-GCM 加密主密钥 (32 字节 base64 编码)
  # 多节点必须一致: SSH 凭据加密后存 Raft 复制到所有节点, 解密必须用同一密钥
  # 留空则开发模式随机生成 (重启后已加密凭据无法解密, 仅限开发)
  # 生成新密钥: openssl rand -base64 32
  master_key: ""

# 资源监控与告警 (v0.6.3+)
# 采集器定时向在线 Agent 下发 COLLECT_METRICS, 结果存内存环形缓冲(2 小时历史);
# 告警引擎按规则评估, 持续超阈值达设定时长触发, 走 Webhook 通知。
monitor:
  # 采集周期(秒), 默认 30。环形缓冲容量 240 点 ≈ 2 小时
  collect_interval_sec: 30

  # 告警 Webhook (留空则仅记日志不发通知)
  # type 支持: dingtalk(钉钉) / feishu(飞书) / wechat(企业微信) / generic(通用 JSON POST)
  webhook_type: ""
  webhook_url: ""

  # 告警规则: 持续时长内(基于采样点)指标全部超阈值才触发, 恢复后发 resolved
  rules:
    - name: high-cpu
      metric: cpu        # cpu / memory / disk
      threshold: 80      # 百分比
      duration_sec: 300  # 持续 5 分钟
    - name: high-memory
      metric: memory
      threshold: 85
      duration_sec: 300
    - name: high-disk
      metric: disk
      threshold: 90
      duration_sec: 300
