# deepsea-server 控制面配置文件
# 复制为 server.yaml 后修改。启动时通过 -config config/server.yaml 指定路径,
# 不指定则默认查找 ./config/server.yaml, 文件不存在则用内置默认值。

# Raft 节点 ID (集群内唯一, 如 node1 / node2 / node3)
node_id: node1

# Raft 相关配置
raft:
  # 本节点 Raft 通信地址 (多节点部署用内网 IP, 不能用 0.0.0.0)
  addr: 127.0.0.1:7000
  # Raft 数据目录 (日志/快照/bbolt, 必须持久化)
  data_dir: raft-data
  # 加入已有集群时填 Leader 的 Raft 地址; 为空表示自己是首节点(bootstrap)
  join: ""

# HTTP 监听地址 (供前端访问 + REST API)
http:
  addr: :8080

# gRPC 监听地址 (供 Agent 连接)
grpc:
  addr: :9090

# 环境变量 (不在配置文件中, 通过系统环境变量设置):
#   JWT_SECRET      - JWT 签名密钥 (生产必须设置)
#   ADMIN_PASSWORD  - 初始管理员密码 (默认 admin123)
#   MASTER_KEY      - SSH 凭据 AES-GCM 加密主密钥 (32 字节 base64)
